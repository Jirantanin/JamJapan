# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jamjapan"

# Auth (nuxt-auth-utils)
NUXT_SESSION_PASSWORD="your-session-password-here-minimum-32-characters-long"
NUXT_OAUTH_GOOGLE_CLIENT_ID="your-google-client-id-here"
NUXT_OAUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# Gemini AI (Image Generation)
GEMINI_API_KEY="your-gemini-api-key-here"

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
