{
  "name": "JamJapan",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:push": "cross-env NODE_ENV=development prisma db push",
    "db:seed": "cross-env NODE_ENV=development npx tsx prisma/seed.ts",
    "db:reset": "cross-env NODE_ENV=development prisma db push --force-reset && cross-env NODE_ENV=development npx tsx prisma/seed.ts",
    "test": "cross-env NODE_ENV=development vitest run",
    "test:watch": "cross-env NODE_ENV=development vitest",
    "test:coverage": "cross-env NODE_ENV=development vitest run --coverage",
    "test:e2e": "cross-env NODE_ENV=development npx playwright test"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "leaflet": "^1.9.4",
    "nuxt": "^3.21.1",
    "nuxt-auth-utils": "^0.5.29",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.18.0",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.8.3",
    "playwright-core": "^1.58.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
