// Production schema — PostgreSQL (Railway)
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatar        String?
  role          String         @default("USER") // "USER" | "ADMIN"
  provider      String
  providerId    String
  routes        Route[]
  routeRequests RouteRequest[]
  votes         Vote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([provider, providerId])
}

model Route {
  id               String   @id // slug เช่น "shinjuku-to-golden-gai"
  title            String
  description      String
  city             String
  difficulty       String
  estimatedMinutes Int
  distanceMeters   Int
  coverImage       String?
  startLat         Float
  startLng         Float
  startName        String?
  endLat           Float
  endLng           Float
  endName          String?
  tags             String   @default("[]") // JSON string
  status           String   @default("published") // "draft" | "published" | "unpublished"
  source           String   @default("official")  // "official" | "community"
  steps            Step[]
  routeRequests    RouteRequest[]
  createdBy        User?    @relation(fields: [createdById], references: [id])
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([city])
  @@index([difficulty])
  @@index([status])
  @@index([source])
}

model Step {
  id               String  @id @default(cuid())
  order            Int
  instruction      String
  image            String?
  locationLat      Float
  locationLng      Float
  locationName     String?
  distanceFromPrev Int?
  note             String?
  route            Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId          String

  @@index([routeId])
}

model RouteRequest {
  id               String   @id @default(cuid())
  title            String
  description      String
  city             String
  startPoint       String
  endPoint         String
  status           String   @default("pending") // "pending" | "fulfilled" | "closed"
  voteCount        Int      @default(0)
  votes            Vote[]
  fulfilledRoute   Route?   @relation(fields: [fulfilledRouteId], references: [id])
  fulfilledRouteId String?
  createdBy        User     @relation(fields: [createdById], references: [id])
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([voteCount])
}

model Vote {
  id             String       @id @default(cuid())
  routeRequest   RouteRequest @relation(fields: [routeRequestId], references: [id], onDelete: Cascade)
  routeRequestId String
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime     @default(now())

  @@unique([routeRequestId, userId])
}
