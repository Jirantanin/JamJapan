{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "npx prisma db push && node .output/server/index.mjs",
    "healthcheckPath": "/api/cities",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
